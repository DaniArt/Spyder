<Window x:Class="Spy.UI.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="520" Height="240"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True">

    <Border CornerRadius="18" Background="#0B1E3A" Padding="22">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.55" Color="#000000"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="Spyder" Foreground="White" FontSize="26" FontWeight="Bold"/>
            <TextBlock Text="Author DaniArt" Foreground="#99FFFFFF" FontSize="14" Margin="0,6,0,0"/>
            <ProgressBar Margin="0,24,0,0" Height="10" IsIndeterminate="True"/>
        </StackPanel>
    </Border>
</Window>
