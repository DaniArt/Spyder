<Window x:Class="Spy.UI.LocatorManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Locator Manager"
        WindowStartupLocation="CenterOwner"
        Height="360" Width="520"
        ResizeMode="CanResize"
        WindowStyle="ToolWindow">
    <Border Background="#132A52" Padding="10">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <TextBlock Text="Locator file:" Foreground="White"/>
                <TextBlock x:Name="TxtPath"
                           Foreground="#99FFFFFF"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="Change file" Width="90" Margin="0,0,8,0" Click="BtnChangeFile_Click"/>
                <Button Content="Clear selected" Width="100" Margin="0,0,8,0" Click="BtnClearSelected_Click"/>
                <Button Content="Clear ALL" Width="80" Margin="0,0,8,0" Click="BtnClearAll_Click"/>
                <Button Content="Close" Width="80" Click="BtnClose_Click"/>
            </StackPanel>

            <ListBox x:Name="Lst"
                     BorderThickness="0"
                     Background="#132A52"
                     Foreground="White">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,6" Padding="6" Background="#17315F" CornerRadius="6">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SelectorPreview}"
                                               Foreground="#99FFFFFF"
                                               FontSize="11"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Button Content="Clear"
                                        Width="60"
                                        Margin="8,0,0,0"
                                        HorizontalAlignment="Right"
                                        DockPanel.Dock="Right"
                                        Tag="{Binding Name}"
                                        Click="BtnClearItem_Click"/>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</Window>

