<Window x:Class="Spy.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Spy.UI"
        Title="DaniArt Spyder"
        Height="650" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>

        <!-- Colors -->
        <SolidColorBrush x:Key="Bg" Color="#0B1E3A"/>
        <SolidColorBrush x:Key="Card" Color="#132A52"/>
        <SolidColorBrush x:Key="Card2" Color="#17315F"/>
        <SolidColorBrush x:Key="TextDim" Color="#99FFFFFF"/>
        <SolidColorBrush x:Key="Accent" Color="#2E5BFF"/>

        <!-- Button style (hover + pressed) -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="s" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="s"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.03" Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="s"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.03" Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="b"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.95" Duration="0:0:0.08"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="s"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1" Duration="0:0:0.10"/>
                                            <DoubleAnimation Storyboard.TargetName="s"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1" Duration="0:0:0.10"/>
                                            <DoubleAnimation Storyboard.TargetName="b"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.10"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Hierarchy tree item style (modern, with child items) -->
        <!-- Явный ключ по типу, чтобы гарантированно переопределить системный стиль -->
        <Style x:Key="{x:Type TreeViewItem}" TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Border x:Name="SelectionBorder"
                                    Grid.Row="0"
                                    Background="Transparent"
                                    CornerRadius="6"
                                    Margin="2,0,2,0">
                                <DockPanel LastChildFill="True">
                                    <Path x:Name="Expander"
                                          Width="8" Height="8"
                                          Margin="4,0,4,0"
                                          VerticalAlignment="Center"
                                          Stroke="{StaticResource TextDim}"
                                          StrokeThickness="1.2"
                                          Data="M 0 0 L 5 4 L 0 8"
                                          Visibility="Collapsed"/>

                                    <!-- ВАЖНО: привязать контент к Header, иначе будет пусто -->
                                    <ContentPresenter Margin="2,2,6,2"
                                                      VerticalAlignment="Center"
                                                      ContentSource="Header"/>
                                </DockPanel>
                            </Border>

                            <!-- Children -->
                            <ItemsPresenter x:Name="ItemsHost"
                                            Grid.Row="1"
                                            Margin="18,0,0,0"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="Expander" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="Expander" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="90"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="SelectionBorder" Property="Background" Value="#233B6C"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SelectionBorder" Property="Background" Value="#1A315F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="PropRowTemplate">
            <Grid Margin="0,1,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Key}"
                           Foreground="{StaticResource TextDim}"
                           Margin="4,1,8,1"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Column="1"
                         Text="{Binding Value, Mode=OneWay}"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="White"
                         Padding="2,1,2,1"
                         VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ChainLineTemplate">
            <TextBlock Text="{Binding}"
                       Foreground="White"
                       FontFamily="Consolas"
                       Margin="6,1,0,1"/>
        </DataTemplate>

    </Window.Resources>

    <!-- Outer glow shadow -->
    <Border CornerRadius="18" Background="{StaticResource Bg}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.55" Color="#000000"/>
        </Border.Effect>

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="18"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Grid Grid.Row="0" Background="#0A1931" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="Spyder" Foreground="White" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="  •  " Foreground="{StaticResource TextDim}" FontSize="12" Margin="8,2,0,0"/>
                    <TextBlock Text="Main"
                               Foreground="{StaticResource TextDim}"
                               FontSize="12"
                               Margin="0,2,0,0"
                               Cursor="Hand"
                               MouseLeftButtonDown="MainLabel_MouseLeftButtonDown"/>
                    <TextBlock Text="  •  " Foreground="{StaticResource TextDim}" FontSize="12" Margin="8,2,0,0"/>
                    <TextBlock Text="About"
                               Foreground="{StaticResource TextDim}"
                               FontSize="12"
                               Margin="0,2,0,0"
                               Cursor="Hand"
                               MouseLeftButtonDown="AboutLabel_MouseLeftButtonDown"/>
                </StackPanel>

                <!-- window buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button Width="36" Height="28" Margin="0,0,6,0" Content="—"
                            Click="BtnMinimize_Click"
                            Background="Transparent" Foreground="White" BorderThickness="0" />
                    <Button Width="36" Height="28" Margin="0,0,6,0" Content="□"
                            Click="BtnMaximize_Click"
                            Background="Transparent" Foreground="White" BorderThickness="0" />
                    <Button Width="36" Height="28" Content="✕"
                            Click="BtnClose_Click"
                            Background="Transparent" Foreground="White" BorderThickness="0" />
                </StackPanel>
            </Grid>

            <!-- MAIN -->
            <Grid Grid.Row="1" Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Parent Tree -->
                <Border Background="{StaticResource Card}" CornerRadius="14" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Hierarchy" Foreground="White" FontSize="14" FontWeight="SemiBold"/>

                        <TreeView x:Name="TreeHierarchy"
                                  Grid.Row="1"
                                  Margin="0,10,0,10"
                                  Background="Transparent"
                                  Foreground="White"
                                  BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <TreeView.Resources>
                                <DataTemplate DataType="{x:Type local:HierarchyNode}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- Номер уровня в квадрате, как в CSS-примере -->
                                        <Border x:Name="IndexBadge"
                                                CornerRadius="4"
                                                Background="{StaticResource Card2}"
                                                BorderBrush="{StaticResource Accent}"
                                                BorderThickness="1"
                                                Padding="4,1"
                                                Margin="0,0,6,0"
                                                MinWidth="22"
                                                HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Index}"
                                                       Foreground="White"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"/>
                                        </Border>

                                        <!-- Иконка для системных/процесс/оконных узлов, когда Index пустой -->
                                        <TextBlock x:Name="KindIcon"
                                                   Text="{Binding KindIcon}"
                                                   Margin="0,0,6,0"
                                                   Foreground="{StaticResource Accent}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Visibility="Collapsed"/>

                                        <TextBlock Text="{Binding Text}"
                                                   Foreground="White"
                                                   FontSize="13"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <!-- Если Index пустой -> прячем бейдж, показываем иконку -->
                                        <DataTrigger Binding="{Binding Index}" Value="{x:Null}">
                                            <Setter TargetName="IndexBadge" Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="KindIcon" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </TreeView.Resources>
                        </TreeView>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="Ctrl + Shift + F — горячая клавиша захвата"
                                       Foreground="{StaticResource TextDim}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <Button x:Name="BtnSpy"
                                    PreviewMouseLeftButtonDown="BtnSpy_PreviewMouseLeftButtonDown"
                                    Content="Drag Target"
                                    Background="{StaticResource Card2}"
                                    Foreground="White"
                                    BorderBrush="{StaticResource Accent}"
                                    BorderThickness="1"
                                    Padding="16,7"
                                    MinWidth="110"
                                    HorizontalContentAlignment="Center"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- RIGHT: Selector + Main/About content -->
                <Border Grid.Column="2" Background="{StaticResource Card}" CornerRadius="14" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Selector -->
                            <RowDefinition Height="Auto"/>  <!-- Locator file info + manage -->
                            <RowDefinition Height="*"/>    <!-- Content (tabs without headers) -->
                        </Grid.RowDefinitions>

                        <!-- Selector preview -->
                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Selector"
                                       Foreground="White"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>

                            <TextBox x:Name="SelectorText"
                                     Grid.Row="0" Grid.Column="1"
                                     Margin="0,0,8,0"
                                     Background="{StaticResource Card2}"
                                     Foreground="White"
                                     BorderBrush="{StaticResource Card2}"
                                     BorderThickness="1"
                                     FontSize="12"
                                     IsReadOnly="True"
                                     VerticalContentAlignment="Center"
                                     Padding="6,2,6,2"/>

                            <Button x:Name="BtnCopySelector"
                                    Grid.Row="0" Grid.Column="2"
                                    Margin="0,0,6,0"
                                    Content="Copy"
                                    Style="{StaticResource AccentButton}"
                                    Padding="10,4"
                                    Click="BtnCopySelector_Click"/>

                            <Button x:Name="BtnAddSelector"
                                    Grid.Row="0" Grid.Column="3"
                                    Content="Add"
                                    Style="{StaticResource AccentButton}"
                                    Padding="10,4"
                                    Click="BtnAddSelector_Click"/>

                            <StackPanel Grid.Row="1" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,6,0,0">
                                <CheckBox x:Name="ChkVclMode"
                                          Margin="0,0,6,0"
                                          VerticalAlignment="Center"
                                          Content="Enable VCL introspection"
                                          Foreground="White"
                                          Checked="ChkVclMode_Checked"
                                          Unchecked="ChkVclMode_Unchecked"/>

                                <Button x:Name="BtnSelectApp"
                                        Content="Select App..."
                                        Background="{StaticResource Card2}"
                                        Foreground="White"
                                        BorderBrush="{StaticResource Accent}"
                                        BorderThickness="1"
                                        Padding="10,4"
                                        Margin="0,0,6,0"
                                        Visibility="Collapsed"
                                        Click="BtnSelectApp_Click"/>

                                <TextBlock x:Name="LblVclStatus"
                                           Margin="4,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextDim}"
                                           FontSize="11"
                                           Text="VCL: Off"/>

                                <CheckBox x:Name="ChkFileLogging"
                                          Margin="8,0,0,0"
                                          VerticalAlignment="Center"
                                          Content="Log to file"
                                          Foreground="White"
                                          Checked="ChkFileLogging_Checked"
                                          Unchecked="ChkFileLogging_Unchecked"/>
                            </StackPanel>
                        </Grid>

                        <!-- Locator file info + Manage -->
                        <Grid Grid.Row="1" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="LocatorFileLabel"
                                       Grid.Column="0"
                                       Text="Current locator file: (none)"
                                       Foreground="{StaticResource TextDim}"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>

                            <Button x:Name="BtnCreateLocatorFile"
                                    Grid.Column="1"
                                    Content="File..."
                                    Background="{StaticResource Card2}"
                                    Foreground="White"
                                    BorderBrush="{StaticResource Accent}"
                                    BorderThickness="1"
                                    Padding="8,3"
                                    Margin="8,0,0,0"
                                    Click="BtnCreateLocatorFile_Click"/>

                            <Button x:Name="BtnManageLocators"
                                    Grid.Column="2"
                                    Content="Manage"
                                    Background="{StaticResource Card2}"
                                    Foreground="White"
                                    BorderBrush="{StaticResource Accent}"
                                    BorderThickness="1"
                                    Padding="8,3"
                                    Margin="8,0,0,0"
                                    Click="BtnManageLocators_Click"/>
                        </Grid>

                        <!-- Main / About content controlled из заголовка -->
                        <TabControl x:Name="MainTabs"
                                    Grid.Row="2"
                                    Background="Transparent"
                                    BorderThickness="0">
                            <TabControl.Resources>
                                <!-- Скрываем стандартные заголовки вкладок -->
                                <Style TargetType="TabItem">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Style>
                            </TabControl.Resources>
                            <!-- Main tab -->
                            <TabItem Header="Main">
                                <Grid Margin="0,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Properties"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="1"
                                                Content="Copy All"
                                                Style="{StaticResource AccentButton}"
                                                Padding="8,2"
                                                FontSize="11"
                                                Click="BtnCopyProps_Click"/>
                                    </Grid>

                                    <ScrollViewer Grid.Row="1"
                                                  Margin="0,10,0,0"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel>
                                            <Expander x:Name="ExpObject" Header="OBJECT" IsExpanded="True" Foreground="White">
                                                <Border Background="{StaticResource Card2}" CornerRadius="10" Padding="8" Margin="0,6,0,0">
                                                    <ItemsControl x:Name="ListObject" ItemTemplate="{StaticResource PropRowTemplate}"/>
                                                </Border>
                                            </Expander>

                                            <Expander x:Name="ExpVcl" Header="VCL OBJECT" IsExpanded="True" Foreground="White" Margin="0,8,0,0">
                                                <Border Background="{StaticResource Card2}" CornerRadius="10" Padding="8" Margin="0,6,0,0">
                                                    <StackPanel>
                                                        <ItemsControl x:Name="ListVcl" ItemTemplate="{StaticResource PropRowTemplate}"/>
                                                        <Border Background="{StaticResource Card}" CornerRadius="8" Padding="6" Margin="0,10,0,0">
                                                            <ItemsControl x:Name="ListVclChain" ItemTemplate="{StaticResource ChainLineTemplate}"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                            </Expander>

                                            <Expander x:Name="ExpWindow" Header="WINDOW" IsExpanded="False" Foreground="White" Margin="0,8,0,0">
                                                <Border Background="{StaticResource Card2}" CornerRadius="10" Padding="8" Margin="0,6,0,0">
                                                    <ItemsControl x:Name="ListWin32" ItemTemplate="{StaticResource PropRowTemplate}"/>
                                                </Border>
                                            </Expander>

                                            <Expander x:Name="ExpUia" Header="UI AUTOMATION" IsExpanded="False" Foreground="White" Margin="0,8,0,0">
                                                <Border Background="{StaticResource Card2}" CornerRadius="10" Padding="8" Margin="0,6,0,0">
                                                    <ItemsControl x:Name="ListUia" ItemTemplate="{StaticResource PropRowTemplate}"/>
                                                </Border>
                                            </Expander>

                                            <Expander x:Name="ExpMsaa" Header="MSAA" IsExpanded="False" Foreground="White" Margin="0,8,0,0">
                                                <Border Background="{StaticResource Card2}" CornerRadius="10" Padding="8" Margin="0,6,0,0">
                                                    <ItemsControl x:Name="ListMsaa" ItemTemplate="{StaticResource PropRowTemplate}"/>
                                                </Border>
                                            </Expander>

                                            <Expander x:Name="ExpLocator" Header="LOCATOR PREVIEW" IsExpanded="False" Foreground="White" Margin="0,8,0,0">
                                                <Border Background="{StaticResource Card2}" CornerRadius="10" Padding="8" Margin="0,6,0,0">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="220"/>
                                                            <RowDefinition Height="10"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
                                                            <Button x:Name="BtnCopyLocatorJson"
                                                                    Content="Copy locator JSON only"
                                                                    Background="{StaticResource Card}"
                                                                    Foreground="White"
                                                                    BorderBrush="{StaticResource Accent}"
                                                                    BorderThickness="1"
                                                                    Padding="10,4"
                                                                    Click="BtnCopyLocatorJson_Click"/>
                                                        </StackPanel>

                                                        <TreeView x:Name="TreeLocator"
                                                                  Grid.Row="1"
                                                                  Background="{StaticResource Card}"
                                                                  BorderBrush="{StaticResource Card}"
                                                                  BorderThickness="0">
                                                            <TreeView.ItemTemplate>
                                                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{Binding Key}"
                                                                                   Foreground="{StaticResource TextDim}"/>
                                                                        <TextBlock Grid.Column="1"
                                                                                   Text="{Binding Separator}"
                                                                                   Foreground="{StaticResource TextDim}"/>
                                                                        <TextBlock Grid.Column="2"
                                                                                   Text="{Binding Value}"
                                                                                   Foreground="{Binding ValueBrush}"/>
                                                                    </Grid>
                                                                </HierarchicalDataTemplate>
                                                            </TreeView.ItemTemplate>
                                                        </TreeView>

                                                        <TextBox x:Name="TxtLocatorJson"
                                                                 Grid.Row="3"
                                                                 TextWrapping="NoWrap"
                                                                 FontFamily="Consolas"
                                                                 Background="{StaticResource Card}"
                                                                 Foreground="White"
                                                                 BorderBrush="{StaticResource Card}"
                                                                 BorderThickness="0"
                                                                 IsReadOnly="True"
                                                                 AcceptsReturn="True"
                                                                 VerticalScrollBarVisibility="Auto"
                                                                 HorizontalScrollBarVisibility="Auto"/>
                                                    </Grid>
                                                </Border>
                                            </Expander>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </TabItem>

                            <!-- About tab -->
                            <TabItem Header="About">
                                <StackPanel Margin="4,8,4,4">
                                    <TextBlock Text="About Spyder"
                                               Foreground="White"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Tool: Spyder"
                                               Foreground="{StaticResource TextDim}"
                                               Margin="0,8,0,0"/>
                                    <TextBlock Text="Version: 3.0"
                                               Foreground="{StaticResource TextDim}"/>
                                    <TextBlock Text="Author: Daniyar Sagatov"
                                               Foreground="{StaticResource TextDim}"
                                               Margin="0,4,0,0"/>
                                    <TextBlock Text="LinkedIn: linkedin.com/in/daniyarsagatov/"
                                               Foreground="{StaticResource TextDim}"
                                               Margin="0,0,0,8"/>
                                </StackPanel>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>
            </Grid>

            <!-- resize grip -->
            <ResizeGrip Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,6,6"/>
        </Grid>
    </Border>
</Window>
