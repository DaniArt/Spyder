<Window x:Class="Spy.UI.ProcessPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Application"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        ResizeMode="CanResize"
        WindowStyle="ToolWindow">
  <Border Background="#132A52" Padding="10">
    <DockPanel>
      <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
        <Button Content="Refresh" Width="80" Margin="0,0,8,0" Click="BtnRefresh_Click"/>
        <Button Content="Select" Width="80" Margin="0,0,8,0" Click="BtnSelect_Click"/>
        <Button Content="Cancel" Width="80" Click="BtnCancel_Click"/>
      </StackPanel>
      <ListView x:Name="Lst" Width="640" Height="360">
        <ListView.View>
          <GridView>
            <GridViewColumn Header="PID" Width="60" DisplayMemberBinding="{Binding Pid}"/>
            <GridViewColumn Header="Process" Width="160" DisplayMemberBinding="{Binding Name}"/>
            <GridViewColumn Header="Title" Width="260" DisplayMemberBinding="{Binding Title}"/>
            <GridViewColumn Header="Path" Width="140" DisplayMemberBinding="{Binding Path}"/>
          </GridView>
        </ListView.View>
      </ListView>
    </DockPanel>
  </Border>
</Window>
